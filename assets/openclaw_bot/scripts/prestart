#!/bin/bash
#
# systemd ExecStartPre helper for openclaw-matrix-bot.service.
# Stages three runtime files under $RUNTIME_DIRECTORY (set by
# systemd for the user unit):
#   access-token  - the bot's Matrix access token from Secrets Manager
#   gateway-token - the OpenClaw daemon's loopback gateway token,
#                   extracted from the openclaw.json state file
#                   (openclaw stores it there rather than in a
#                   standalone file)
#   env           - K=V file loaded back into the unit via
#                   EnvironmentFile=; populates CONTROL_ROOM_ID
#                   from SSM Parameter Store

set -euo pipefail

: "${RUNTIME_DIRECTORY:?RUNTIME_DIRECTORY must be set by systemd}"
: "${BOT_TOKEN_SECRET_ID:?BOT_TOKEN_SECRET_ID must be set in the unit}"
: "${CONTROL_ROOM_PARAM:?CONTROL_ROOM_PARAM must be set in the unit}"
: "${OPENCLAW_STATE_FILE:?OPENCLAW_STATE_FILE must be set in the unit}"

aws secretsmanager get-secret-value \
  --secret-id "$BOT_TOKEN_SECRET_ID" \
  --query SecretString --output text |
  python3 -c 'import json,sys;print(json.load(sys.stdin)["token"])' \
    >"$RUNTIME_DIRECTORY/access-token"
chmod 0600 "$RUNTIME_DIRECTORY/access-token"

python3 -c 'import json,sys;print(json.load(open(sys.argv[1]))["gateway"]["auth"]["token"])' \
  "$OPENCLAW_STATE_FILE" \
  >"$RUNTIME_DIRECTORY/gateway-token"
chmod 0600 "$RUNTIME_DIRECTORY/gateway-token"

# The control-room param may not exist on first deploy: in that
# case the bot itself creates the room and writes the ID back here.
# Treat missing-param as empty so the bot's bootstrap branch fires.
control_room_id="$(
  aws ssm get-parameter \
    --name "$CONTROL_ROOM_PARAM" \
    --query Parameter.Value --output text 2>/dev/null ||
    true
)"

printf 'CONTROL_ROOM_ID=%s\n' "$control_room_id" \
  >"$RUNTIME_DIRECTORY/env"
chmod 0600 "$RUNTIME_DIRECTORY/env"
